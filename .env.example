# =============================================================================
# scriviq — Environment Variables Template
# =============================================================================
# This file is committed to source control as a reference.
# To set up your environment:
#   1. Copy this file:  cp .env.example .env.local
#   2. Fill in each value (see comments for where to find each one)
#   3. Never commit .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=

# -----------------------------------------------------------------------------
# NextAuth.js
# Generate: openssl rand -base64 32
# Docs: https://next-auth.js.org/configuration/options#secret
# -----------------------------------------------------------------------------
NEXTAUTH_URL=
NEXTAUTH_SECRET=

# -----------------------------------------------------------------------------
# AWS — Core credentials
# Create an IAM user with the policy in infra/policies/scriviq-app-policy.json
# Docs: https://docs.aws.amazon.com/IAM/latest/UserGuide/id_credentials_access-keys.html
# -----------------------------------------------------------------------------
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# AWS Cognito
# Values are printed by `cdk deploy` or found in AWS Console → Cognito → User Pools
# -----------------------------------------------------------------------------
AWS_COGNITO_USER_POOL_ID=
AWS_COGNITO_CLIENT_ID=

# -----------------------------------------------------------------------------
# AWS S3
# Bucket is created by CDK. Name format: scriviq-contracts-<account-id>
# -----------------------------------------------------------------------------
AWS_S3_BUCKET=

# -----------------------------------------------------------------------------
# AWS DynamoDB
# Table is created by CDK with name "scriviq-main"
# -----------------------------------------------------------------------------
DYNAMODB_TABLE=scriviq-main

# -----------------------------------------------------------------------------
# AWS SES — Email delivery
# Sender domain must be verified in SES
# Production: request SES production access (exits sandbox)
# -----------------------------------------------------------------------------
SES_FROM_ADDRESS=alerts@scriviq.com

# -----------------------------------------------------------------------------
# OpenAI
# Get key: https://platform.openai.com/api-keys
# Model used: gpt-4o-mini (configurable in lib/openai/extract.ts)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Stripe
# Test keys (sk_test_...) for development, live keys (sk_live_...) for production
# Create webhook at: https://dashboard.stripe.com/webhooks
# Price ID: create a $49/mo recurring price at https://dashboard.stripe.com/products
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
